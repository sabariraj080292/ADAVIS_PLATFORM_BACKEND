# ============================================
# Adavis AI Platform - Environment Variables
# ============================================
# Copy this file to .env.dev, .env.staging, or .env.prod
# and update values accordingly.

# ============================================
# Application Configuration
# ============================================
APP_NAME=Adavis Platform
APP_VERSION=1.0.0
APP_ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# ============================================
# Server Ports
# ============================================
API_GATEWAY_PORT=9080
AUTH_SERVICE_PORT=9081
MDM_SERVICE_PORT=9083
IIOT_SERVICE_PORT=9085
LICENSE_SERVICE_PORT=8082
AUDIT_SERVICE_PORT=8084

# Direct service port overrides used by some services
LICENSE_PORT=8082
AUDIT_PORT=8084

# ============================================
# Database Configuration
# ============================================
# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=37017
MONGODB_DATABASE=adavis_platform
MONGODB_USERNAME=admin
MONGODB_PASSWORD=Admin123!
MONGODB_AUTH_SOURCE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=8379
REDIS_PASSWORD=Redis123!

# ============================================
# Kafka Configuration
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:10092

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-for-development-minimum-256-bits
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ============================================
# Security Configuration
# ============================================
PASSWORD_POLICY_MIN_LENGTH=8
PASSWORD_POLICY_REQUIRE_UPPERCASE=true
PASSWORD_POLICY_REQUIRE_LOWERCASE=true
PASSWORD_POLICY_REQUIRE_NUMBERS=true
PASSWORD_POLICY_REQUIRE_SPECIAL=true
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=30

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# Service Base URLs (Inter-service Calls)
# ============================================
AUTH_SERVICE_BASE_URL=http://localhost:9081
LICENSE_SERVICE_BASE_URL=http://localhost:8082
AUDIT_SERVICE_BASE_URL=http://localhost:8084

# ============================================
# DMS Storage (MDM-hosted for Phase 1)
# ============================================
DMS_STORAGE_PROVIDER=LOCAL
DMS_STORAGE_LOCAL_ROOT_PATH=./data/dms/local
DMS_STORAGE_CLOUD_ROOT_PATH=./data/dms/cloud
DMS_STORAGE_CLOUD_BUCKET=adavis-dms
DMS_DOWNLOAD_URL_TTL_MINUTES=15

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=20
RATE_LIMIT_MDM=100

# ============================================
# Feature Flags
# ============================================
FEATURE_IIOT_ENABLED=false
FEATURE_AI_ENABLED=false
FEATURE_EBR_ENABLED=false
FEATURE_MFA_ENABLED=false