# ============================================
# Adavis Platform - AWS Production Environment
# ============================================
# Copy this file to .env.aws and replace placeholders before deployment.
# Do not commit the generated .env.aws file.

# Runtime profile
SPRING_PROFILES_ACTIVE=aws

# Optional per-service JVM flags
GATEWAY_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC
AUTH_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC
MDM_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC
IIOT_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC
LICENSE_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC
AUDIT_JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC

# Security
JWT_SECRET=local-dev-jwt-secret-key-256-bits-minimum!

# EC2 host IP used by Docker containers to reach MongoDB, Redis, and Kafka when they run on the same instance.
EC2_HOST_IP=172.31.41.202

# Data services
# The AWS compose file derives MongoDB/Redis/Kafka endpoints from EC2_HOST_IP for same-host testing.
MONGODB_URI=mongodb://admin:Admin123!@172.31.41.202:37017/adavis_platform?authSource=admin
REDIS_HOST=172.31.41.202
REDIS_PORT=8379
REDIS_PASSWORD=Redis123!

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=172.31.41.202:10092
KAFKA_TOPIC_AUDIT=audit-events

# Mail settings for auth-service
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# API gateway CORS
CORS_ALLOWED_ORIGINS=https://REPLACE_FRONTEND_DOMAIN

# DMS storage
DMS_STORAGE_PROVIDER=LOCAL
DMS_STORAGE_LOCAL_ROOT_PATH=/app/data/dms/local
DMS_STORAGE_CLOUD_ROOT_PATH=/app/data/dms/cloud
DMS_STORAGE_CLOUD_BUCKET=adavis-dms
DMS_DOWNLOAD_URL_TTL_MINUTES=15
